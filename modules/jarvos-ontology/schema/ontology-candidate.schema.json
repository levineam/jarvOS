{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvos.dev/schemas/ontology-candidate.schema.json",
  "title": "jarvOS ontology candidate",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "status",
    "signal_type",
    "source",
    "created_at",
    "updated_at",
    "confidence",
    "proposed_target",
    "proposal"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "type": { "const": "ontology-candidate" },
    "status": {
      "type": "string",
      "enum": ["new", "reviewing", "promoted", "dismissed", "resolved", "stale"]
    },
    "signal_type": {
      "type": "string",
      "enum": ["belief", "prediction", "goal", "value", "core-self", "project", "higher-order", "question", "relationship", "other"]
    },
    "source": {
      "type": "object",
      "required": ["type", "ref"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "quote": { "type": "string" },
        "capture_event_id": { "type": "string" },
        "note_path": { "type": "string" },
        "paperclip_issue": { "type": "string" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "reviewed_at": { "type": ["string", "null"], "format": "date-time" },
    "reviewer": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "proposed_target": { "type": "string", "minLength": 1 },
    "proposal": { "type": "string", "minLength": 1 },
    "outcome": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ontology_anchor": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] }
      }
    }
  }
}
