{
  "schemaVersion": "jarvos.profile.v1",
  "id": "minimal",
  "title": "Minimal",
  "description": "Portable jarvOS starter workspace with core files, config, vault folders, agent-context, and an authenticated control-plane module.",
  "public": true,
  "required": [
    "node",
    "workspace",
    "vault",
    "config-schema",
    "agent-context",
    "control-plane",
    "codex-runtime"
  ],
  "optional": [],
  "writes": [
    "core-files",
    "jarvos.config.json",
    "vault-folders"
  ],
  "doctorChecks": [
    "node-version",
    "workspace-files",
    "config-schema",
    "vault-path",
    "vault-path-stale",
    "journal-conflict",
    "agent-context-package",
    "control-plane-module"
  ]
}
