{
  "schemaVersion": 1,
  "id": "codex",
  "displayName": "Codex",
  "sharedAgentContext": {
    "mcpServer": "modules/jarvos-agent-context/scripts/jarvos-mcp.js",
    "requiredTools": [
      "jarvos_current_work",
      "jarvos_recall",
      "jarvos_create_note",
      "jarvos_startup_brief",
      "jarvos_hydrate",
      "jarvos_control_plane"
    ]
  },
  "targets": [
    {
      "id": "codex-cli",
      "kind": "cli",
      "mcp": {
        "supported": true,
        "registration": "codex mcp add jarvos -- node <mcp-server>"
      },
      "hydration": {
        "mode": "hook",
        "event": "SessionStart",
        "script": "jarvos-session-start-hook.js",
        "defaultMaxChars": 12000
      }
    },
    {
      "id": "codex-app-local",
      "kind": "desktop-local",
      "mcp": {
        "supported": true,
        "registration": "shared ~/.codex/config.toml MCP server"
      },
      "hydration": {
        "mode": "hook",
        "event": "SessionStart",
        "script": "jarvos-session-start-hook.js",
        "defaultMaxChars": 12000
      }
    }
  ],
  "setup": {
    "script": "setup.sh"
  },
  "configWrites": {
    "backupBeforeWrite": true,
    "paths": [
      "~/.codex/config.toml"
    ]
  },
  "unsupportedCapabilities": [],
  "controlPlane": {
    "module": "modules/jarvos-control-plane/scripts/jarvos-manager.js",
    "hostService": "JARVOS_CONTROL_PLANE_SERVICE_MODULE",
    "credentialFile": "JARVOS_CONTROL_PLANE_CREDENTIAL_FILE",
    "parity": "Human CLI and agent MCP delegate to the same installed authenticated application service. Setup registers only the non-secret credential file path; the MCP server reads the secret at runtime."
  },
  "verification": [
    "codex mcp get jarvos",
    "node runtimes/codex/jarvos-session-start-hook.js",
    "node modules/jarvos-runtime-kit/scripts/jarvos-runtime-kit.js check codex"
  ]
}
