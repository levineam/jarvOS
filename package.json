{
  "name": "jarvos-bootstrap",
  "version": "0.3.0",
  "description": "Bootstrap installer for jarvOS — sets up a portable personal AI operating layer for compatible agent runtimes",
  "keywords": [
    "jarvos",
    "openclaw",
    "ai-assistant",
    "personal-os",
    "bootstrap"
  ],
  "homepage": "https://github.com/levineam/jarvOS",
  "repository": {
    "type": "git",
    "url": "https://github.com/levineam/jarvOS.git"
  },
  "license": "MIT",
  "main": "bootstrap.js",
  "files": [
    "lib/",
    "bootstrap.js",
    "bootstrap.sh",
    "jarvos.config.schema.json",
    "modules/jarvos-agent-context/README.md",
    "modules/jarvos-agent-context/package.json",
    "modules/jarvos-agent-context/scripts/",
    "modules/jarvos-agent-context/src/",
    "modules/jarvos-skills/README.md",
    "modules/jarvos-skills/docs/",
    "modules/jarvos-skills/manifest.json",
    "modules/jarvos-skills/package.json",
    "modules/jarvos-skills/packs/",
    "modules/jarvos-skills/scripts/",
    "modules/jarvos-skills/skills/",
    "modules/jarvos-skills/src/",
    "profiles/",
    "scripts/jarvos.js",
    "templates/"
  ],
  "bin": {
    "jarvos": "scripts/jarvos.js",
    "jarvos-bootstrap": "scripts/jarvos.js",
    "jarvos-init": "scripts/jarvos.js"
  },
  "scripts": {
    "bootstrap": "node bootstrap.js",
    "clawpatch": "node scripts/clawpatch-runner.js",
    "clawpatch:doctor": "node scripts/clawpatch-runner.js doctor",
    "clawpatch:map": "node scripts/clawpatch-runner.js map",
    "clawpatch:status": "node scripts/clawpatch-runner.js status",
    "clawpatch:review:dry-run": "node scripts/clawpatch-runner.js review --limit 1 --dry-run",
    "test": "bash tests/smoke-test.sh && node tests/modules-smoke-test.js && node tests/agentify-concurrent-write-test.js && node tests/cli-smoke-test.js && bash scripts/smoke-test.sh",
    "test:bootstrap": "bash tests/smoke-test.sh",
    "test:modules": "node tests/modules-smoke-test.js && node tests/agentify-concurrent-write-test.js",
    "test:structure": "bash scripts/smoke-test.sh",
    "release:check": "node scripts/release-readiness-check.js",
    "release:drift": "node scripts/unreleased-drift-check.js",
    "release:check:candidate": "node scripts/release-readiness-check.js --allow-dirty --allow-unreleased"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "clawpatch": "^0.2.0"
  }
}
